unction(l){if(elim.indexOf(l)>=0)return;var btn=document.createElement('button');btn.className='opt';btn.innerHTML='<span class=\"oltr\">'+l.toUpperCase()+'</span>'+q[l];btn.onclick=function(){answer(l,btn);};g.appendChild(btn);});}\nfunction answer(ch,btn){var q=questions[cur];document.querySelectorAll('.opt').forEach(function(b){b.disabled=true;});if(ch===q.correct){btn.classList.add('correct');setTimeout(function(){cur++;elim=[];if(cur>=questions.length){endGame(true);}else{render();}},1200);}else{btn.classList.add('wrong');document.querySelectorAll('.opt').forEach(function(b){if(b.textContent.indexOf(q[q.correct])>=0)b.classList.add('correct');});setTimeout(function(){endGame(false);},1500);}}\nfunction endGame(won){document.getElementById('qcard').style.display='none';document.getElementById('ogrid').style.display='none';var es=document.getElementById('end');es.style.display='block';if(won){document.getElementById('etit').textContent='MILLIONAIRE!';document.getElementById('eprz').textContent='You won EUR 1,000,000!';}else{var sh=safe.filter(function(s){return s<cur;}).pop();var banked=sh!==undefined?'EUR '+prizes[sh]:'EUR 0';document.getElementById('etit').textContent='Game Over!';document.getElementById('eprz').textContent='You bank '+banked;}}\nfunction use5050(){if(llUsed.f)return;llUsed.f=true;document.getElementById('ll1').disabled=true;var q=questions[cur];var wrong=['a','b','c','d'].filter(function(l){return l!==q.correct;});elim=[wrong[0],wrong[1]];render();}\nfunction usePhone(){if(llUsed.p)return;llUsed.p=true;document.getElementById('ll2').disabled=true;var q=questions[cur];var hb=document.getElementById('hbox');hb.style.display='block';hb.textContent='Friend says: \"I think it starts with: '+q[q.correct].substring(0,Math.ceil(q[q.correct].length*.6))+'...\"';}\nfunction useAudience(){if(llUsed.a)return;llUsed.a=true;document.getElementById('ll3').disabled=true;var q=questions[cur];var pcts={};var letters=['a','b','c','d'];pcts[q.correct]=Math.floor(