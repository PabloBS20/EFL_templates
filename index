rgin-bottom:3px;\"><span>Accuracy</span><span id=\"rpct\">0%</span></div>\n        <div class=\"pbw\"><div class=\"pbf\" id=\"rbar\" style=\"width:0%\"></div></div>\n      </div>\n      <button class=\"baga\" onclick=\"location.reload()\">&#128260; Play Again</button>\n    </div>\n  </div>\n</div>\n<script>\nvar gameData=[\n  {letter:'A',condition:'STARTS WITH A',question:\"Disorder preventing formation of new memories.\",answer:\"Amnesia\"},\n  {letter:'B',condition:'STARTS WITH B',question:'Synonym of \"increase\". Also used in videogames for extra power.',answer:\"Boost\"},\n  {letter:'C',condition:'STARTS WITH C',question:'Modal verb expressing ability in the present.',answer:\"Can\"},\n  {letter:'D',condition:'STARTS WITH D',question:'To think about other things while being awake.',answer:\"Daydream\"},\n  {letter:'E',condition:'STARTS WITH E',question:'Organ that allows you to hear.',answer:\"Ear\"},\n  {letter:'F',condition:'STARTS WITH F',question:'The way a food or drink tastes.',answer:\"Flavour\"},\n  {letter:'G',condition:'STARTS WITH G',question:'Someone who has been found guilty in court.',answer:\"Guilty\"},\n  {letter:'H',condition:'STARTS WITH H',question:'Structure requiring the gerund form.',answer:[\"Have fun\",\"Have no problem\"]},\n  {letter:'I',condition:'STARTS WITH I',question:'Lack of ability.',answer:\"Inability\"},\n  {letter:'J',condition:'STARTS WITH J',question:'Person who serves justice in a court.',answer:\"Judge\"},\n  {letter:'K',condition:'CONTAINS K',question:'Cybercriminal who breaks into systems.',answer:\"Hacker\"},\n  {letter:'L',condition:'STARTS WITH L',question:'Verb that has same meaning with infinitive or gerund.',answer:[\"Like\",\"Love\"]},\n  {letter:'M',condition:'STARTS WITH M',question:'Expression implying someone is trying hard.',answer:\"Make an effort\"},\n  {letter:'N',condition:'CONTAINS N',question:'Period of time a criminal must spend in prison.',answer:\"Sentence\"},\n  {letter:'O',condition:'STARTS WITH O