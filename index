function loadFrame(id) {
  var iframe = document.getElementById(id + '-frame');
  if (!iframe || iframe.dataset.loaded) return;
  var blob = new Blob([GAMES[id]], {type: 'text/html'});
  iframe.src = URL.createObjectURL(blob);
  iframe.dataset.loaded = '1';
  var pre = document.getElementById(id + '-codepre');
  if (pre) pre.textContent = GAMES[id];
}
window.addEventListener('load', function() {
  ['pp','mm','jj','tb','cl','er','im','sq'].forEach(loadFrame);
});
function sw(gid, tab, btn) {
  var sec = document.getElementById(gid);
  sec.querySelectorAll('.tab-panel').forEach(function(p){p.classList.remove('on');});
  sec.querySelectorAll('.tb').forEach(function(b){b.classList.remove('on');});
  document.getElementById(gid + '-' + tab).classList.add('on');
  btn.classList.add('on');
  if (tab === 'prev') loadFrame(gid);
  if (tab === 'code') {
    var pre = document.getElementById(gid + '-codepre');
    if (pre && pre.textContent === 'Loading...') pre.textContent = GAMES[gid];
  }
}
function downloadGame(gid) {
  var blob = new Blob([GAMES[gid]], {type: 'text/html'});
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  var names = {pp:'pasapalabra',mm:'millionaire',jj:'jeopardy',tb:'taboo',cl:'cluedo',er:'escape_room',im:'imposter',sq:'squares'};
  a.download = (names[gid] || gid) + '_template.html';
  a.click();
}
function copyPrompt(elId, btn) {
  var text = document.getElementById(elId).textContent;
  navigator.clipboard.writeText(text).then(function() {
    var orig = btn.textContent;
    btn.textContent = 'Copied! Paste into Claude ✓';
    btn.style.background = '#5ee7b0';
    btn.style.color = '#0a0a0f';
    setTimeout(function(){ btn.textContent = orig; btn.style.background = ''; btn.style.color = ''; }, 2500);
  });
}
function copyCode(gid, btn) {
  navigator.clipboard.writeText(GAMES[gid]).then(function() {
    var orig = btn.textContent;
    btn.textContent = 'Copied!';
    btn.style.background = '#5ee7b0';
    btn.style.color = '#0a0a0f';
    setTimeout(function(){ btn.textContent = orig; btn.style.background = ''; btn.style.color = ''; }, 2200);
  });
}
function openFull(gid) {
  var blob = new Blob([GAMES[gid]], {type: 'text/html'});
  var url = URL.createObjectURL(blob);
  var win = window.open(url, '_blank');
  if (!win) {
    // Popup blocked — navigate current tab instead
    window.location.href = url;
  }
}
function setLang(lang) {
  document.getElementById('btn-en').classList.toggle('active', lang === 'en');
  document.getElementById('btn-es').classList.toggle('active', lang === 'es');
  document.querySelectorAll('[data-en]').forEach(function(el) {
    var val = el.getAttribute('data-' + lang);
    if (!val) return;
    if (val.indexOf('<') >= 0) el.innerHTML = val;
    else el.textContent = val;
  });
}
var obs = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) {
    if (e.isIntersecting) {
      var id = e.target.id;
      document.querySelectorAll('.np').forEach(function(p) {
        p.classList.toggle('active', p.getAttribute('href') === '#' + id);
      });
    }
  });
}, {threshold: 0.3});
document.querySelectorAll('.gs').forEach(function(s){ obs.observe(s); });
