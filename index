pace;}\n.mq{font-size:1rem;line-height:1.5;margin-bottom:18px;}\n.mans{background:rgba(255,215,0,.1);border:1px solid rgba(255,215,0,.3);border-radius:8px;padding:9px 14px;font-size:.9rem;color:#ffd700;display:none;margin-bottom:14px;}\n.mbtns{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}\n.mb{padding:9px 18px;border:none;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;}\n.mb-rev{background:#1a337a;color:white;border:2px solid #3355aa;}\n.mb-ok{background:#16a34a;color:white;}\n.mb-no{background:#dc2626;color:white;}\n.mb-cl{background:#374151;color:white;}\n.sb{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:10px;}\n.sbtn{background:#1a337a;color:#93c5fd;border:1px solid #3355aa;padding:5px 11px;border-radius:6px;font-size:.72rem;cursor:pointer;}\n</style>\n</head>\n<body>\n<h1>JEOPARDY!</h1>\n<div class=\"teams\" id=\"tdis\"></div>\n<div class=\"board\" id=\"board\"></div>\n<div class=\"modal\" id=\"modal\">\n  <div class=\"mc\">\n    <div class=\"mcat\" id=\"mcat\"></div>\n    <div class=\"mpts\" id=\"mpts\"></div>\n    <div class=\"mq\" id=\"mq\"></div>\n    <div class=\"mans\" id=\"mans\"></div>\n    <div class=\"mbtns\" id=\"mbtns\"></div>\n    <div id=\"sarea\" style=\"margin-top:10px;display:none;\">\n      <div style=\"font-size:.7rem;color:#8899cc;margin-bottom:7px;\">Award points to:</div>\n      <div id=\"award\" class=\"sb\"></div>\n    </div>\n  </div>\n</div>\n<script>\nvar bdata={\n  cats:[\"Irregular Verbs\",\"British Culture\",\"Phrasal Verbs\",\"Grammar\",\"Famous Quotes\"],\n  pts:[100,200,300,400,500],\n  clues:[\n    [{q:\"Past tense of 'go'\",a:\"What is 'went'?\"},{q:\"Past tense of 'write'\",a:\"What is 'wrote'?\"},{q:\"Past tense of 'fly'\",a:\"What is 'flew'?\"},{q:\"Past tense of 'choose'\",a:\"What is 'chose'?\"},{q:\"Past tense of 'forbid'\",a:\"What is 'forbade'?\",dd:true}],\n    [{q:\"City where the Beatles were from\",a:\"What is Liverpool?\"},{q:\"Britain's national flower\",a: