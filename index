ement('div');h.className='ch';h.textContent=c;b.appendChild(h);});bdata.clues.forEach(function(cat,ci){cat.forEach(function(cell,pi){var d=document.createElement('div');d.className='cell'+(cell.dd?' dd':'');d.id='c'+ci+'_'+pi;d.innerHTML='<span class=\"pts\">'+bdata.pts[pi]+'</span>';d.onclick=function(){openCell(ci,pi);};b.appendChild(d);});});}\nfunction openCell(ci,pi){var cell=bdata.clues[ci][pi];curC={ci:ci,pi:pi};document.getElementById('mcat').textContent=bdata.cats[ci];document.getElementById('mpts').textContent=(cell.dd?'DAILY DOUBLE - ':'')+bdata.pts[pi]+' pts';document.getElementById('mq').textContent=cell.q;document.getElementById('mans').style.display='none';document.getElementById('mans').textContent=cell.a;document.getElementById('sarea').style.display='none';document.getElementById('mbtns').innerHTML='<button class=\"mb mb-rev\" onclick=\"revA()\">Reveal Answer</button><button class=\"mb mb-cl\" onclick=\"closeM()\">Close</button>';document.getElementById('modal').style.display='flex';}\nfunction revA(){document.getElementById('mans').style.display='block';document.getElementById('mbtns').innerHTML='<button class=\"mb mb-cl\" onclick=\"closeM()\">Close</button>';var sa=document.getElementById('sarea'),aw=document.getElementById('award');sa.style.display='block';aw.innerHTML=teams.map(function(t,i){return '<button class=\"sbtn\" onclick=\"awd('+i+')\">'+t.name+' +'+bdata.pts[curC.pi]+'</button>';}).join('');}\nfunction awd(ti){teams[ti].score+=bdata.pts[curC.pi];document.getElementById('ts'+ti).textContent=teams[ti].score;closeM();}\nfunction closeM(){if(curC){var el=document.getElementById('c'+curC.ci+'_'+curC.pi);el.className='cell used';el.innerHTML='';}document.getElementById('modal').style.display='none';}\nrenderTeams();renderBoard();\n<" + "/script>\n</body>\n</html>";
