al = inp.value.trim().toUpperCase();\n  if (val === activeRoom.answer.toUpperCase()) {\n    inp.className = \"pp-input ok\";\n    solved.push(activeRoom.id);\n    buildProgressStrip();\n    updateProgress();\n    setTimeout(function(){\n      if (solved.length === E.rooms.length) { showSuccess(); return; }\n      buildRooms();\n      // Auto-open next room\n      var nextIdx = E.rooms.findIndex(function(r){return r.id===activeRoom.id;}) + 1;\n      if (nextIdx < E.rooms.length) openRoom(E.rooms[nextIdx]);\n      else document.getElementById(\"puzzle-panel\").innerHTML = '<div class=\"pp-empty\">All rooms solved!</div>';\n    }, 700);\n  } else {\n    inp.className = \"pp-input no\";\n    timerSec = Math.max(0, timerSec - 120); // -2 min penalty\n    updateTimerDisplay();\n    setTimeout(function(){ inp.className = \"pp-input\"; }, 400);\n  }\n}\n\nfunction showHint(btn, hintId) {\n  if (!hintUsed[hintId]) {\n    hintUsed[hintId] = true;\n    timerSec = Math.max(0, timerSec - 120);\n    updateTimerDisplay();\n    btn.textContent = \"Hint used (-2 min)\";\n    btn.disabled = true;\n  }\n  var box = document.getElementById(hintId);\n  if (box) box.style.display = \"block\";\n}\n\n// ── TIMER ─────────────────────────────────────────────────────────────────────\nfunction startTimer() {\n  updateTimerDisplay();\n  timerInterval = setInterval(function(){\n    timerSec--;\n    updateTimerDisplay();\n    if (timerSec <= 0) { clearInterval(timerInterval); timeUp(); }\n  }, 1000);\n}\n\nfunction updateTimerDisplay() {\n  var m = Math.floor(timerSec/60), s = timerSec%60;\n  var disp = document.getElementById(\"timer-display\");\n  disp.textContent = m + \":\" + (s<10?\"0\":\"\") + s;\n  disp.className = \"timer-display\" + (timerSec < 300 ? \" danger\" : \"\");\n}\n\nfunction timeUp() {\n  // Show how far they got\n  document.getElementById(\"game\").classList.remove(\"active\");\n  document.getElementById(\"success\").classList.add(\"active\");\n  document.getElementById(\"suc-time\").textContent = \"Time ran out!\";\n  document.getElementById(\"suc-msg\").textContent = solved.length + \" of \" + E.rooms.length + \" rooms solved. So close! Try again.\";\n  document.querySelector(\".suc-title\").textContent = \"Time's Up!\";\n  document.querySelector(\".suc-title\").style.color = \"#c0392b\";\n  document.querySelector(\".suc-icon\").textContent = \"&#8987;\";\n}\n\nfunction updateProgress() {\n  var n = solved.length, tot = E.rooms.length;\n  document.getElementById(\"progress-label\").textContent = n + \" / \" + tot + \" rooms\";\n}\n\n// ── PROGRESS STRIP ────────────────────────────────────────────────────────────\nfunction buildProgressStrip() {\n  var strip = document.getElementById(\"progress-strip\");\n  strip.innerHTML = E.rooms.map(function(r, i){\n    var cls = \"ps-dot\";\n    if (solved.indexOf(r.id) >= 0) cls += \" done\";\n    else if (i === 0 || solved.indexOf(E.rooms[i-1].id) >= 0) cls += \" active\";\n    return '<div class=\"' + cls + '\" title=\"' + r.name + '\"></div>';\n  }).join(\"\");\n}\n\n// ── SUCCESS ───────────────────────────────────────────────────────────────────\nfunction showSuccess() {\n  clearInterval(timerInterval);\n  var elapsed = Math.round((Date.now() - startTime) / 1000);\n  var em = Math.floor(elapsed/60), es = elapsed%60;\n  document.getElementById(\"game\").classList.remove(\"active\");\n  document.getElementById(\"success\").classList.add(\"active\");\n  document.getElementById(\"suc-time\").textContent = \"Completed in \" + em + \"m \" + es + \"s\";\n  document.getElementById(\"suc-msg\").textContent = E.success;\n}\n<" + "/script>\n</body>\n</html>\n";

