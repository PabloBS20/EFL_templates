ackground:#2e2418;color:#8a7a60;}\n#log{background:#080604;border:1px solid #1a1610;border-radius:4px;padding:4px;font-size:.6rem;\n  color:#4a6a4a;font-family:monospace;height:80px;overflow-y:auto;}\n.nb-cat{color:#c8922a;font-size:.55rem;text-transform:uppercase;letter-spacing:1px;\n  margin:5px 0 2px;border-bottom:1px solid #2e2418;padding-bottom:1px;}\n.nb-g{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:3px;}\n.ni{padding:2px 4px;border-radius:2px;background:#14110d;font-size:.64rem;cursor:pointer;user-select:none;}\n.ni:hover{background:#1e1a14;}\n.ni.x{text-decoration:line-through;color:#3a3028;background:#0e0c0a;}\n.cb{background:#0a0c14;border:1px dashed #2a2a40;border-radius:6px;padding:8px;margin-bottom:6px;}\n.cb h4{color:#60a5fa;font-size:.58rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;}\n.ci{font-size:.67rem;line-height:1.5;padding:3px 6px;border-radius:3px;margin-bottom:2px;}\n.ci.fa{background:#0d1a0d;border-left:2px solid #4ade80;}\n.ci.he{background:#1a0d0d;border-left:2px solid #f87171;}\n.ci.qu{background:#0d0d1a;border-left:2px solid #60a5fa;}\n.cil{font-size:.52rem;text-transform:uppercase;letter-spacing:.5px;opacity:.6;display:block;margin-bottom:1px;}\n.li{background:#0d0a14;border:1px solid #1e1830;border-radius:4px;padding:5px 7px;margin-bottom:3px;font-size:.67rem;color:#b0a8d0;}\n.li span{color:#4455aa;font-weight:700;margin-right:4px;}\n\n/* ── END ── */\n#s-end{align-items:center;justify-content:center;text-align:center;padding:24px;background:rgba(0,0,0,.95);z-index:200;}\n.et{font-size:1.8rem;font-weight:900;margin-bottom:8px;}\n.es{font-size:.88rem;color:#8a8070;margin-bottom:20px;max-width:440px;line-height:1.7;}\n.es strong{color:#e8e4d8;}\n.eb{padding:10px 24px;border:none;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;}\n.eb-lobby{background:linear-gradient(135deg,#c8922a,#a87020);color:#12100e;}\n\n::-webkit-scrollbar{width:3px;}\n::-webkit-scrollbar-track{background:#0a0906;}\n::-webkit-scrollbar-thumb{background:#2e2418;border-radius:2px;}\n</style>\n</head>\n<body>\n\n<!-- LOBBY -->\n<div id=\"s-lobby\" class=\"screen on\">\n  <div class=\"l-title\">&#128373; CLUEDO</div>\n  <p class=\"l-scene\">Lord Blackwood has been found dead in his manor. Six guests were present the night of the crime. Investigate the rooms, share clues, and be the first to name the culprit!</p>\n  <div class=\"setup-box\">\n    <h3>Players (2&#8211;6) &#8212; enter name &amp; choose character</h3>\n    <div id=\"player-rows\"></div>\n    <button class=\"add-btn\" id=\"add-btn\">+ Add player</button>\n  </div>\n  <p class=\"char-note\" id=\"char-note\"></p>\n  <button class=\"start-btn\" id=\"start-btn\" disabled>BEGIN INVESTIGATION</button>\n</div>\n\n<!-- GAME -->\n<div id=\"s-game\" class=\"screen\">\n  <div id=\"board-wrap\">\n    <div id=\"board-container\">\n      <img id=\"board-img\" alt=\"Blackwood Manor\">\n      <div id=\"turn-banner\">...</div>\n    </div>\n  </div>\n  <div id=\"sidebar\">\n    <div class=\"sh\">\n      <div class=\"sh-title\">Blackwood Manor</div>\n      <div class=\"sh-turn\" id=\"sh-turn\"></div>\n    </div>\n    <div class=\"stabs\" id=\"stabs\"></div>\n    <div class=\"tp on\" id=\"tp-actions\">\n      <div class=\"sc\">\n        <h4>Movement</h4>\n        <div class=\"dice-row\"><div class=\"die\" id=\"die1\">&#9856;</div><div class=\"die\" id=\"die2\">&#9856;</div></div>\n        <div class=\"d-info\" id=\"d-info\">Roll to move!</div>\n        <button class=\"rbtn\" id=\"roll-btn\">Roll Dice</button>\n      </div>\n      <div class=\"sc\">\n        <h4>Suggestion &amp; Accusation</h4>\n        <div class=\"rd\" id=\"room-disp\">Move to a room first</div>\n        <select class=\"sug-sel\" id=\"sel-sus\"></select>\n        <select class=\"sug-sel\" id=\"sel-wep\"></select>\n        <button class=\"abtn ab-s\" id=\"btn-suggest\">Make Suggestion</button>\n        <button class=\"abtn ab-a\" id=\"btn-accuse\">&#9888; Final Accusation</button>\n        <button class=\"abtn ab-e\" id=\"btn-endturn\">End Turn &#8594; Next Player</button>\n      </div>\n      <div class=\"sc\"><h4>Game Log</h4><div id=\"log\"></div></div>\n    </div>\n    <div class=\"tp\" id=\"tp-notebook\">\n      <div class=\"sc\"><h4>Detective Notebook</h4><div id=\"nb\"></div></div>\n    </div>\n    <div class=\"tp\" id=\"tp-clues\"><div id=\"clues-panel\"></div></div>\n    <div class=\"tp\" id=\"tp-lang\"><div class=\"sc\"><h4>Language Bank</h4><div id=\"lang-panel\"></div></div></div>\n  </div>\n</div>\n\n<!-- END -->\n<div id=\"s-end\" class=\"screen\">\n  <div class=\"et\" id=\"et\"></div>\n  <div class=\"es\" id=\"es\"></div>\n  <button class=\"eb eb-lobby\" id=\"btn-newgame\">New Game</button>\n</div>\n\n<script>\n// ════════════════════════════════════════════════════════\n// DATA\n// ════════════════════════════════════════════════════════\nvar BOARD_B64 = \"\";\n\nvar G = {\n  suspects: [\n    {id:\"SC\",name:\"Col. Scarlet\", role:\"Retired Army Officer\",color:\"#ef4444\",motive:\"Disputed the inheritance\",      alibi:\"Claims he was in the Billiard Room\"},\n    {id:\"PL\",name:\"Prof. Plum\",   role:\"University Professor\", color:\"#a855f7\",motive:\"Lord B. knew his dark secret\",  alibi:\"Says he was reading in the Library\"},\n    {id:\"MS\",name:\"Mrs. Sage\",    role:\"Manor Housekeeper\",    color:\"#22c55e\",motive:\"Had not been paid for months\",  alibi:\"Claims she was cleaning the Kitchen\"},\n    {id:\"MP\",name:\"Mr. Peacock\",  role:\"Business Partner\",     color:\"#3b82f6\",motive:\"A bad deal gone very wrong\",    alibi:\"Says he was on the phone in the Study\"},\n    {id:\"RR\",name:\"Rev. Rose\",    role:\"Local Vicar\",          color:\"#ec4899\",motive:\"Blackmailed by the victim\",     alibi:\"Claims she was in the Conservatory\"},\n    {id:\"WW\",name:\"Dr. White\",    role:\"Family Physician\",     color:\"#94a3b8\",motive:\"Forged a medical certificate\",  alibi:\"Says she was in the Dining Room\"}\n  ],\n  weapons: [\"Lead Pipe\",\"Candlestick\",\"Revolver\",\"Rope\",\"Spanner\",\"Dagger\"],\n  rooms: [\n    {id:\"KI\",name:\"Kitchen\"},      {id:\"BA\",name:\"Ballroom\"},   {id:\"CO\",name:\"Conservatory\"},\n    {id:\"BI\",name:\"Billiard Room\"},{id:\"ST\",name:\"Study\"},       {id:\"LI\",name:\"Library\"},\n    {id:\"LO\",name:\"Lounge\"},       {id:\"DI\",name:\"Dining Room\"},{id:\"HA\",name:\"Hall\"}\n  ],\n  clues: {\n    \"Col. Scarlet\": {facts:[\"Prof. Plum was seen in the Library at 9pm\",\"The Rope was found near the Ballroom\"],herring:\"Someone was spotted near the Kitchen with a candle\",quest:\"Ask Mrs. Sage: did you see anyone in the corridors after dinner?\"},\n    \"Prof. Plum\":   {facts:[\"Rev. Rose has no alibi witness\",\"The Revolver is missing from the Study cabinet\"],herring:\"A Dagger was found in the Kitchen sink\",quest:\"Ask Dr. White: what were you really doing in the Dining Room?\"},\n    \"Mrs. Sage\":    {facts:[\"Mr. Peacock and Lord B. had a fierce argument at 8pm\",\"The Conservatory door was unlocked\"],herring:\"Col. Scarlet was heard shouting near the Billiard Room\",quest:\"Ask Prof. Plum: which book were you reading?\"},\n    \"Mr. Peacock\":  {facts:[\"Dr. White was seen leaving the Dining Room at 9:30pm\",\"The Spanner belongs to the groundskeeper\"],herring:\"Mrs. Sage had a strange package delivered\",quest:\"Ask Rev. Rose: why did she leave the Conservatory between 8 and 9pm?\"},\n    \"Rev. Rose\":    {facts:[\"Mrs. Sage is owed six months salary\",\"The Candlestick had fingerprints wiped clean\"],herring:\"Prof. Plum sent an unusual telegram\",quest:\"Ask Col. Scarlet: can anyone confirm you were in the Billiard Room?\"},\n    \"Dr. White\":    {facts:[\"Col. Scarlet was last to see Lord B. alive\",\"The Lead Pipe was hidden under the Kitchen floor\"],herring:\"Mr. Peacock was heard arguing about money\",quest:\"Ask Mr. Peacock: what business deal went wrong?\"}\n  },\n  solution: {suspect:\"Col. Scarlet\", location:\"Billiard Room\", weapon:\"Lead Pipe\"},\n  langBank: [\n    \"I suspect ___ because...\",\n    \"Could you tell me where you were when...?\",\n    \"I can rule out ___ since...\",\n    \"My accusation is ___ with the ___ in the ___.\",\n    \"That does not add up because...\",\n    \"Do you have any evidence that...?\",\n    \"According to the clues, it seems likely that...\",\n    \"I am not convinced by your alibi because...\",\n    \"The most suspicious person is ___ due to...\",\n    \"In conclusion, the culprit must be ___ because...\"\n  ]\n};\n\n// Room hotspot positions (as fraction of board image size)\nvar HOTSPOTS = [\n  {id:\"KI\",name:\"Kitchen\",       lx:.04,ly:.04,w:.26,h:.26},\n  {id:\"BA\",name:\"Ballroom\",      lx:.35,ly:.02,w:.30,h:.27},\n  {id:\"CO\",name:\"Conservatory\",  lx:.70,ly:.04,w:.26,h:.26},\n  {id:\"BI\",name:\"Billiard Room\", lx:.04,ly:.38,w:.26,h:.24},\n  {id:\"ST\",name:\"Study\",         lx:.70,ly:.38,w:.26,h:.24},\n  {id:\"LO\",name:\"Lounge\",        lx:.04,ly:.70,w:.26,h:.26},\n  {id:\"DI\",name:\"Dining Room\",   lx:.70,ly:.70,w:.26,h:.26},\n  {id:\"HA\",name:\"Hall\",          lx:.35,ly:.70,w:.30,h:.27},\n  {id:\"LI\",name:\"Library\",       lx:.35,ly:.35,w:.30,h:.30}\n];\n\n// ════════════════════════════════════════════════════════\n// STATE\n// ════════════════════════════════════════════════════════\nvar players = [], curIdx = 0, positions = {}, weaponLoc = {}, roll = 0, logs = [];\nvar playerCount = 0;\nvar boardSize = 400;\n\n// ════════════════════════════════════════════════════════\n// LOBBY\n// ════════════════════════════════════════════════════════\nfunction addPlayerRow() {\n  var idx = playerCount++;\n  var row = document.createElement(\"div\");\n  row.className = \"player-row\";\n\n  var nameIn = document.createElement(\"input\");\n  nameIn.type = \"text\";\n  nameIn.placeholder = \"Player \" + (idx + 1) + \" name\";\n  nameIn.addEventListener(\"input\", validateLobby);\n\n  var sel = document.createElement(\"select\");\n  var defOpt = document.createElement(\"option\");\n  defOpt.value = \"\";\n  defOpt.textContent = \"-- Choose character --\";\n  sel.appendChild(defOpt);\n  G.suspects.forEach(function(s) {\n    var opt = document.createElement(\"option\");\n    opt.value = s.id;\n    opt.textContent = s.name + \" \\u2014 \" + s.role;\n    sel.appendChild(opt);\n  });\n  sel.addEventListener(\"change\", function() { syncTaken(); validateLobby(); });\n\n  var del = document.createElement(\"button\");\n  del.className = \"del-btn\";\n  del.textContent = \"\\u00d7\";\n  del.addEventListener(\"click\", function() { row.remove(); syncTaken(); validateLobby(); });\n\n  row.appendChild(nameIn);\n  row.appendChild(sel);\n  row.appendChild(del);\n  document.getElementById(\"player-rows\").appendChild(row);\n  validateLobby();\n}\n\nfunction syncTaken() {\n  var taken = {};\n  document.querySelectorAll(\".player-row select\").forEach(function(s) {\n    if (s.value) taken[s.value] = true;\n  });\n  document.querySelectorAll(\".player-row select\").forEach(function(sel) {\n    Array.from(sel.options).forEach(function(opt) {\n      if (!opt.value) return;\n      opt.disabled = (taken[opt.value] && opt.value !== sel.value);\n    });\n  });\n}\n\nfunction validateLobby() {\n  var rows = document.querySelectorAll(\".player-row\");\n  var ok = rows.length >= 2;\n  rows.forEach(function(row) {\n    var n = row.querySelector(\"input\").value.trim();\n    var c = row.querySelector(\"select\").value;\n    if (!n || !c) ok = false;\n  });\n  document.getElementById(\"start-btn\").disabled = !ok;\n  var note = document.getElementById(\"char-note\");\n  if (rows.length < 2) note.textContent = \"Add at least 2 players\";\n  else if (!ok) note.textContent = \"Fill in all names and pick a character for each player\";\n  else note.textContent = \"\\u2713 Ready to investigate!\";\n}\n\n// ════════════════════════════════════════════════════════\n// START GAME\n// ════════════════════════════════════════════════════════\nfunction startGame() {\n  players = [];\n  document.querySelectorAll(\".player-row\").forEach(function(row) {\n    var name = row.querySelector(\"input\").value.trim();\n    var charId = row.querySelector(\"select\").value;\n    var suspect = G.suspects.find(function(s) { return s.id === charId; });\n    if (name && suspect) {\n      players.push({name:name, charName:suspect.name, color:suspect.color, charId:charId, notebook:{}, eliminated:false});\n    }\n  });\n  if (players.length < 2) return;\n  curIdx = 0; roll = 0; logs = [];\n  G.suspects.forEach(function(s, i) { positions[s.name] = G.rooms[i % G.rooms.length].id; });\n  G.weapons.forEach(function(w, i) { weaponLoc[w] = G.rooms[i % G.rooms.length].id; });\n  showScreen(\"s-game\");\n  setupBoard();\n  buildDropdowns();\n  buildLang();\n  buildTabs();\n  refreshSidebar();\n  addLog(\"Investigation begins! \" + players.length + \" detectives.\");\n  addLog(cp().name + \" (\" + cp().charName + \") goes first.\");\n}\n\nfunction resetToLobby() {\n  players = []; playerCount = 0; curIdx = 0;\n  positions = {}; weaponLoc = {}; roll = 0; logs = [];\n  document.getElementById(\"player-rows\").innerHTML = \"\";\n  document.getElementById(\"char-note\").textContent = \"\";\n  document.getElementById(\"start-btn\").disabled = true;\n  showScreen(\"s-lobby\");\n  addPlayerRow();\n  addPlayerRow();\n}\n\nfunction showScreen(id) {\n  document.querySelectorAll(\".screen\").forEach(function(s) { s.classList.remove(\"on\"); });\n  document.getElementById(id).classList.add(\"on\");\n}\n\n// ════════════════════════════════════════════════════════\n// HELPERS\n// ════════════════════════════════════════════════════════\nfunction cp() { return players[curIdx]; }\n\n// ════════════════════════════════════════════════════════\n// BOARD\n// ════════════════════════════════════════════════════════\nfunction setupBoard() {\n  var wrap = document.getElementById(\"board-wrap\");\n  var container = document.getElementById(\"board-container\");\n  var size = Math.min(wrap.clientWidth, wrap.clientHeight, 460);\n  boardSize = size;\n  container.style.width = size + \"px\";\n  container.style.height = size + \"px\";\n  var img = document.getElementById(\"board-img\");\n  img.src = \"data:image/jpeg;base64,\" + BOARD_B64;\n  img.style.width = size + \"px\";\n  img.style.height = size + \"px\";\n\n  // Remove old hotspots / tokens / labels\n  container.querySelectorAll(\".hotspot,.room-lbl,.tok\").forEach(function(e) { e.remove(); });\n\n  HOTSPOTS.forEach(function(hs) {\n    var div = document.createElement(\"div\");\n    div.className = \"hotspot\";\n    div.id = \"hs-\" + hs.id;\n    div.style.left   = (hs.lx * size) + \"px\";\n    div.style.top    = (hs.ly * size) + \"px\";\n    div.style.width  = (hs.w  * size) + \"px\";\n    div.style.height = (hs.h  * size) + \"px\";\n    div.addEventListener(\"click\", function() { moveToRoom(hs.id); });\n    container.appendChild(div);\n\n    var lbl = document.createElement(\"div\");\n    lbl.className = \"room-lbl\";\n    lbl.textContent = hs.name;\n    lbl.style.left = ((hs.lx + hs.w / 2) * size) + \"px\";\n    lbl.style.top  = ((hs.ly + hs.h - 0.05) * size) + \"px\";\n    container.appendChild(lbl);\n  });\n\n  updateBoard();\n}\n\nfunction updateBoard() {\n  var rId = positions[cp().charName];\n  var container = document.getElementById(\"board-container\");\n\n  HOTSPOTS.forEach(function(hs) {\n    var div = document.getElementById(\"hs-\" + hs.id);\n    if (!div) return;\n    var cls = \"hotspot\";\n    if (hs.id === rId) cls += \" my-room\";\n    else if (roll > 0) cls += \" can-move\";\n    div.className = cls;\n  });\n\n  container.querySelectorAll(\".tok\").forEach(function(t) { t.remove(); });\n\n  var roomCounts = {};\n  players.forEach(function(p) {\n    var pRoomId = positions[p.charName];\n    if (!pRoomId) return;\n    var hs = HOTSPOTS.find(function(h) { return h.id === pRoomId; });\n    if (!hs) return;\n    var c = (roomCounts[pRoomId] = (roomCounts[pRoomId] || 0));\n    roomCounts[pRoomId]++;\n    var tok = document.createElement(\"div\");\n    tok.className = \"tok\" + (p.charName === cp().charName ? \" me\" : \"\");\n    tok.style.background = p.color;\n    tok.textContent = p.charId;\n    var col = c % 3, row = Math.floor(c / 3);\n    tok.style.left = ((hs.lx + 0.07 + col * 0.09) * boardSize) + \"px\";\n    tok.style.top  = ((hs.ly + hs.h * 0.55 + row * 0.1) * boardSize) + \"px\";\n    container.appendChild(tok);\n  });\n\n  var room = G.rooms.find(function(r) { return r.id === rId; });\n  var rd = document.getElementById(\"room-disp\");\n  if (rd) {\n    rd.textContent = room ? \"In: \" + room.name : \"Move to a room first\";\n    rd.className = \"rd\" + (room ? \" in\" : \"\");\n  }\n}\n\n// ════════════════════════════════════════════════════════\n// DICE + MOVEMENT\n// ════════════════════════════════════════════════════════\nfunction rollDice() {\n  document.getElementById(\"roll-btn\").disabled = true;\n  var d1 = document.getElementById(\"die1\"), d2 = document.getElementById(\"die2\");\n  var info = document.getElementById(\"d-info\");\n  var faces = [\"&#9856;\",\"&#9857;\",\"&#9858;\",\"&#9859;\",\"&#9860;\",\"&#9861;\"];\n  var n = 0;\n  var anim = setInterval(function() {\n    d1.innerHTML = faces[Math.floor(Math.random() * 6)];\n    d2.innerHTML = faces[Math.floor(Math.random() * 6)];\n    info.textContent = \"Rolling...\";\n    if (++n > 14) {\n      clearInterval(anim);\n      var r1 = Math.floor(Math.random() * 6), r2 = Math.floor(Math.random() * 6);\n      d1.innerHTML = faces[r1]; d2.innerHTML = faces[r2];\n      roll = (r1 + 1) + (r2 + 1);\n      info.textContent = \"Rolled \" + roll + \" \\u2014 click a room\";\n      updateBoard();\n    }\n  }, 70);\n}\n\nfunction moveToRoom(roomId) {\n  if (roll === 0) { addLog(\"Roll the dice first!\"); return; }\n  positions[cp().charName] = roomId;\n  roll = 0;\n  document.getElementById(\"roll-btn\").disabled = false;\n  var room = G.rooms.find(function(r) { return r.id === roomId; });\n  document.getElementById(\"d-info\").textContent = \"Moved to \" + (room ? room.name : roomId);\n  document.getElementById(\"die1\").innerHTML = \"&#9856;\";\n  document.getElementById(\"die2\").innerHTML = \"&#9856;\";\n  updateBoard();\n  addLog(cp().name + \" moved to \" + (room ? room.name : roomId) + \".\");\n}\n\n// ════════════════════════════════════════════════════════\n// SUGGESTION + ACCUSATION\n// ════════════════════════════════════════════════════════\nfunction buildDropdowns() {\n  var ss = document.getElementById(\"sel-sus\"), sw = document.getElementById(\"sel-wep\");\n  ss.innerHTML = \"\";\n  sw.innerHTML = \"\";\n  G.suspects.forEach(function(s) {\n    var o = document.createElement(\"option\");\n    o.textContent = s.name;\n    ss.appendChild(o);\n  });\n  G.weapons.forEach(function(w) {\n    var o = document.createElement(\"option\");\n    o.textContent = w;\n    sw.appendChild(o);\n  });\n}\n\nfunction suggest() {\n  var rId = positions[cp().charName];\n  if (!rId) { addLog(\"Move to a room first!\"); return; }\n  var room = G.rooms.find(function(r) { return r.id === rId; });\n  var sus = document.getElementById(\"sel-sus\").value;\n  var wep = document.getElementById(\"sel-wep\").value;\n  positions[sus] = rId;\n  weaponLoc[wep] = rId;\n  updateBoard();\n  addLog(\"SUGGESTION: \" + sus + \" + \" + wep + \" in \" + room.name + \"!\");\n  addLog(\"Other players: show a matching card if you have one.\");\n}\n\nfunction accuse() {\n  var rId = positions[cp().charName];\n  if (!rId) { addLog(\"Move to a room first!\"); return; }\n  var room = G.rooms.find(function(r) { return r.id === rId; });\n  var sus = document.getElementById(\"sel-sus\").value;\n  var wep = document.getElementById(\"sel-wep\").value;\n  var sol = G.solution;\n  var win = sus === sol.suspect && wep === sol.weapon && room.name === sol.location;\n  showScreen(\"s-end\");\n  var et = document.getElementById(\"et\");\n  var es = document.getElementById(\"es\");\n  if (win) {\n    et.textContent = \"Case Solved!\";\n    et.style.color = \"#4ade80\";\n    es.innerHTML = \"<strong>\" + cp().name + \"</strong> (\" + cp().charName + \") cracked the case!<br>It was <strong>\" + sus + \"</strong> with the <strong>\" + wep + \"</strong> in the <strong>\" + room.name + \"</strong>.\";\n  } else {\n    et.textContent = \"Wrong Accusation!\";\n    et.style.color = \"#f87171\";\n    es.innerHTML = \"<strong>\" + cp().name + \"</strong> was wrong.<br>The answer: <strong>\" + sol.suspect + \"</strong> + <strong>\" + sol.weapon + \"</strong> in <strong>\" + sol.location + \"</strong>.\";\n  }\n}\n\nfunction endTurn() {\n  roll = 0;\n  document.getElementById(\"roll-btn\").disabled = false;\n  document.getElementById(\"die1\").innerHTML = \"&#9856;\";\n  document.getElementById(\"die2\").innerHTML = \"&#9856;\";\n  document.getElementById(\"d-info\").textContent = \"Roll to move!\";\n  do {\n    curIdx = (curIdx + 1) % players.length;\n  } while (players[curIdx].eliminated && players.some(function(p) { return !p.eliminated; }));\n  updateBoard();\n  refreshSidebar();\n  addLog(\"--- \" + cp().name + \" (\" + cp().charName + \") \\u2014 your turn! ---\");\n}\n\n// ════════════════════════════════════════════════════════\n// SIDEBAR\n// ════════════════════════════════════════════════════════\nfunction buildTabs() {\n  var stabs = document.getElementById(\"stabs\");\n  stabs.innerHTML = \"\";\n  var tabs = [{id:\"actions\",label:\"Actions\"},{id:\"notebook\",label:\"Notes\"},{id:\"clues\",label:\"Clues\"},{id:\"lang\",label:\"Phrases\"}];\n  tabs.forEach(function(t, i) {\n    var btn = document.createElement(\"button\");\n    btn.className = \"stab\" + (i === 0 ? \" on\" : \"\");\n    btn.textContent = t.label;\n    btn.setAttribute(\"data-tab\", t.id);\n    btn.addEventListener(\"click\", function() {\n      document.querySelectorAll(\".tp\").forEach(function(p) { p.classList.remove(\"on\"); });\n      document.querySelectorAll(\".stab\").forEach(function(b) { b.classList.remove(\"on\"); });\n      document.getElementById(\"tp-\" + t.id).classList.add(\"on\");\n      btn.classList.add(\"on\");\n    });\n    stabs.appendChild(btn);\n  });\n}\n\nfunction refreshSidebar() {\n  var p = cp();\n  document.getElementById(\"sh-turn\").textContent = p.name + \" \\u2014 \" + p.charName;\n  document.getElementById(\"sh-turn\").style.color = p.color;\n  document.getElementById(\"turn-banner\").textContent = p.name + \"'s turn (\" + p.charName + \")\";\n  document.getElementById(\"turn-banner\").style.borderColor = p.color;\n  document.getElementById(\"turn-banner\").style.color = p.color;\n  buildNotebook();\n  buildClues();\n}\n\n// ════════════════════════════════════════════════════════\n// NOTEBOOK (per player, using data-attributes, no inline onclick)\n// ════════════════════════════════════════════════════════\nfunction buildNotebook() {\n  var p = cp();\n  var nb = document.getElementById(\"nb\");\n  nb.innerHTML = \"\";\n  var cats = [\n    {label:\"Suspects\", items:G.suspects.map(function(s) { return s.name; })},\n    {label:\"Weapons\",  items:G.weapons},\n    {label:\"Rooms\",    items:G.rooms.map(function(r) { return r.name; })}\n  ];\n  cats.forEach(function(cat) {\n    var catDiv = document.createElement(\"div\");\n    catDiv.className = \"nb-cat\";\n    catDiv.textContent = cat.label;\n    nb.appendChild(catDiv);\n    var grid = document.createElement(\"div\");\n    grid.className = \"nb-g\";\n    cat.items.forEach(function(item) {\n      var key = \"k_\" + item.replace(/\\W/g, \"_\");\n      var el = document.createElement(\"div\");\n      el.className = \"ni\" + (p.notebook[key] ? \" x\" : \"\");\n      el.textContent = item;\n      el.setAttribute(\"data-key\", key);\n      el.addEventListener(\"click\", function() {\n        p.notebook[key] = !p.notebook[key];\n        el.className = \"ni\" + (p.notebook[key] ? \" x\" : \"\");\n      });\n      grid.appendChild(el);\n    });\n    nb.appendChild(grid);\n  });\n}\n\n// ════════════════════════════════════════════════════════\n// CLUES (pure DOM, no innerHTML string building with quotes)\n// ════════════════════════════════════════════════════════\nfunction buildClues() {\n  var p = cp();\n  var cs = G.clues[p.charName];\n  var sus = G.suspects.find(function(s) { return s.name === p.charName; });\n  var panel = document.getElementById(\"clues-panel\");\n  panel.innerHTML = \"\";\n\n  if (cs) {\n    var block = document.createElement(\"div\");\n    block.className = \"cb\";\n    var h4 = document.createElement(\"h4\");\n    h4.textContent = p.charName + \"'s Clue Sheet\";\n    block.appendChild(h4);\n    cs.facts.forEach(function(f) {\n      var d = document.createElement(\"div\");\n      d.className = \"ci fa\";\n      d.innerHTML = \"<span class='cil'>Known fact</span>\" + f;\n      block.appendChild(d);\n    });\n    var dh = document.createElement(\"div\");\n    dh.className = \"ci he\";\n    dh.innerHTML = \"<span class='cil'>Red herring</span>\" + cs.herring;\n    block.appendChild(dh);\n    var dq = document.createElement(\"div\");\n    dq.className = \"ci qu\";\n    dq.innerHTML = \"<span class='cil'>Find out</span>\" + cs.quest;\n    block.appendChild(dq);\n    panel.appendChild(block);\n  }\n\n  if (sus) {\n    var card = document.createElement(\"div\");\n    card.className = \"sc\";\n    card.style.borderColor = sus.color + \"44\";\n    var h4c = document.createElement(\"h4\");\n    h4c.textContent = sus.name;\n    h4c.style.color = sus.color;\n    card.appendChild(h4c);\n    var info = document.createElement(\"div\");\n    info.style.cssText = \"font-size:.66rem;line-height:1.9;color:#a09880;\";\n    info.innerHTML = \"<b style='color:#c8c0a8'>Role:</b> \" + sus.role + \"<br>\" +\n                     \"<b style='color:#c8c0a8'>Motive:</b> \" + sus.motive + \"<br>\" +\n                     \"<b style='color:#c8c0a8'>Alibi:</b> \" + sus.alibi;\n    card.appendChild(info);\n    panel.appendChild(card);\n  }\n}\n\n// ════════════════════════════════════════════════════════\n// LANGUAGE BANK\n// ════════════════════════════════════════════════════════\nfunction buildLang() {\n  var lp = document.getElementById(\"lang-panel\");\n  lp.innerHTML = \"\";\n  G.langBank.forEach(function(phrase, i) {\n    var d = document.createElement(\"div\");\n    d.className = \"li\";\n    var span = document.createElement(\"span\");\n    span.textContent = (i + 1) + \".\";\n    d.appendChild(span);\n    d.appendChild(document.createTextNode(\" \" + phrase));\n    lp.appendChild(d);\n  });\n}\n\n// ════════════════════════════════════════════════════════\n// LOG\n// ════════════════════════════════════════════════════════\nfunction addLog(msg) {\n  logs.push(msg);\n  var el = document.getElementById(\"log\");\n  el.innerHTML = \"\";\n  logs.slice(-20).reverse().forEach(function(l) {\n    var d = document.createElement(\"div\");\n    d.textContent = \"> \" + l;\n    el.appendChild(d);\n  });\n}\n\n// ════════════════════════════════════════════════════════\n// WIRE UP BUTTONS (no inline onclick anywhere)\n// ════════════════════════════════════════════════════════\ndocument.getElementById(\"add-btn\").addEventListener(\"click\", addPlayerRow);\ndocument.getElementById(\"start-btn\").addEventListener(\"click\", startGame);\ndocument.getElementById(\"roll-btn\").addEventListener(\"click\", rollDice);\ndocument.getElementById(\"btn-suggest\").addEventListener(\"click\", suggest);\ndocument.getElementById(\"btn-accuse\").addEventListener(\"click\", accuse);\ndocument.getElementById(\"btn-endturn\").addEventListener(\"click\", endTurn);\ndocument.getElementById(\"btn-newgame\").addEventListener(\"click\", resetToLobby);\n\n// ════════════════════════════════════════════════════════\n// BOOT\n// ════════════════════════════════════════════════════════\naddPlayerRow();\naddPlayerRow();\n<" + "/script>\n</body>\n</html>\n";
