ursor:pointer;letter-spacing:2px;text-transform:uppercase;box-shadow:0 4px 24px rgba(200,146,42,.3);transition:all .2s;}\n.intro-btn:hover{transform:scale(1.04);box-shadow:0 6px 32px rgba(200,146,42,.5);}\n\n/* ── MAIN GAME ── */\n#game{flex-direction:row;}\n#rooms-col{flex:1;display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(2,1fr);gap:0;overflow:hidden;}\n#right-col{width:320px;background:var(--panel);border-left:2px solid var(--border);display:flex;flex-direction:column;}\n\n/* ── ROOM CARDS ── */\n.room-card{position:relative;background:var(--locked);border:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .3s;overflow:hidden;padding:16px;}\n.room-card::before{content:'';position:absolute;inset:0;background:var(--room-color,transparent);opacity:.05;transition:.3s;}\n.room-card.unlocked{background:var(--unlocked);}\n.room-card.unlocked::before{opacity:.08;}\n.room-card.solved{background:#0a1a0a;}\n.room-card.solved::before{opacity:.12;}\n.room-card.active-room{box-shadow:inset 0 0 0 2px var(--gold);z-index:2;}\n.room-card:not(.locked-room):hover{transform:scale(1.01);z-index:3;}\n.room-card.locked-room{cursor:default;opacity:.5;}\n.room-icon{font-size:2.2rem;margin-bottom:8px;filter:grayscale(.5);}\n.room-card.solved .room-icon{filter:none;}\n.room-name{font-family:'Cinzel',serif;font-size:.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);text-align:center;}\n.room-card.unlocked .room-name,.room-card.solved .room-name{color:var(--text);}\n.room-status{font-size:.58rem;text-transform:uppercase;letter-spacing:1.5px;margin-top:6px;}\n.room-card.locked-room .room-status{color:#3a2e1a;}\n.room-card.unlocked .room-status{color:var(--gold);}\n.room-card.solved .room-status{color:var(--green);}\n.lock-icon{position:absolute;top:10px;right:10px;font-size:.8rem;opacity:.4;}\n.room-card.solved .lock-icon{opacity:0;}\n.room-progress{position:absolute;bottom:0;left:0;height:3px;background:var(--green);transition:width .5s;}\n\n/* ── RIGHT PANEL ── */\n.rp-header{background:#1a1410;padding:12px 16px;border-bottom:1px solid var(--border);}\n.rp-case-title{font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:2px;color:var(--gold);text-transform:uppercase;}\n.timer-row{display:flex;align-items:center;justify-content:space-between;margin-top:4px;}\n.timer-display{font-family:'Cinzel',serif;font-size:1.4rem;color:var(--gold2);font-weight:700;letter-spacing:2px;}\n.timer-display.danger{color:var(--red);animation:pulse .6s ease-in-out infinite;}\n@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}\n.progress-strip{display:flex;gap:4px;padding:8px 16px;border-bottom:1px solid var(--border);}\n.ps-dot{flex:1;height:6px;border-radius:3px;background:var(--border);transition:background .3s;}\n.ps-dot.done{background:var(--green);}\n.ps-dot.active{background:var(--gold);}\n\n/* PUZZLE PANEL */\n#puzzle-panel{flex:1;overflow-y:auto;padding:14px;}\n.pp-empty{display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-style:italic;font-size:.9rem;text-align:center;padding:20px;}\n.pp-room-name{font-family:'Cinzel',serif;font-size:.85rem;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:4px;}\n.pp-skill{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;}\n.pp-instruction{background:rgba(200,146,42,.07);border:1px solid rgba(200,146,42,.2);border-radius:8px;padding:12px 14px;font-size:.88rem;line-height:1.7;margin-bottom:12px;color:#c0b090;}\n.pp-task{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:14px;font-size:.85rem;line-height:2;margin-bottom:14px;white-space:pre-wrap;color:var(--text);font-family:'Crimson Text',serif;}\n.pp-input-row{display:flex;gap:8px;margin-bottom:8px;}\n.pp-input{flex:1;padding:9px 14px;background:var(--bg);border:2px solid var(--border);border-radius:7px;color:var(--gold2);font-size:.9rem;font-weight:600;font-family:'Cinzel',serif;letter-spacing:3px;text-transform:uppercase;outline:none;}\n.pp-input:focus{border-color:var(--gold);}\n.pp-input.ok{border-color:var(--green);background:#0a1a0a;animation:flash-green .5s;}\n.pp-input.no{border-color:var(--red);animation:shake .3s;}\n@keyframes flash-green{0%,100%{background:#0a1a0a;}50%{background:#0d2a0d;}}\n@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-5px);}75%{transform:translateX(5px);}}\n.pp-unlock-btn{padding:9px 16px;background:linear-gradient(135deg,var(--gold),#a87020);border:none;border-radius:7px;color:#0c0a08;font-family:'Cinzel',serif;font-size:.72rem;font-weight:700;letter-spacing:1px;cursor:pointer;}\n.pp-hint-btn{width:100%;padding:7px;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--muted);font-size:.7rem;cursor:pointer;font-family:'Crimson Text',serif;transition:all .2s;}\n.pp-hint-btn:hover{border-color:var(--gold);color:var(--gold);}\n.pp-hint-box{background:#0a0c18;border:1px dashed #2a2a50;border-radius:6px;padding:10px 12px;font-size:.82rem;color:#8090c0;margin-top:8px;display:none;line-height:1.6;}\n.pp-solved-msg{text-align:center;padding:20px;color:var(--green);}\n.pp-solved-msg .sm-icon{font-size:2.5rem;margin-bottom:8px;}\n.pp-solved-msg p{font-family:'Cinzel',serif;font-size:.8rem;letter-spacing:2px;}\n\n/* ── SUCCESS SCREEN ── */\n#success{align-items:center;justify-content:center;text-align:center;padding:32px;\n  background:radial-gradient(ellipse at 50% 30%,#0a1a08 0%,#0c0a08 70%);}\n.suc-icon{font-size:4rem;margin-bottom:16px;}\n.suc-title{font-family:'Cinzel',serif;font-size:2.5rem;color:var(--green);margin-bottom:8px;}\n.suc-sub{font-size:.9rem;color:var(--muted);letter-spacing:2px;margin-bottom:20px;}\n.suc-time{font-family:'Cinzel',serif;font-size:1.4rem;color:var(--gold);margin-bottom:8px;}\n.suc-msg{max-width:500px;font-size:1rem;line-height:1.8;color:#a0c090;margin-bottom:28px;}\n.suc-btn{font-family:'Cinzel',serif;padding:12px 36px;background:linear-gradient(135deg,var(--green),#1a7a40);border:none;border-radius:8px;color:white;font-size:.9rem;font-weight:700;cursor:pointer;letter-spacing:2px;}\n\n::-webkit-scrollbar{width:4px;}\n::-webkit-scrollbar-track{background:var(--bg);}\n::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}\n</style>\n</head>\n<body>\n\n<!-- INTRO -->\n<div id=\"intro\" class=\"screen active\">\n  <div class=\"intro-badge\">EFL Escape Room</div>\n  <div class=\"intro-title\" id=\"intro-title\"></div>\n  <div class=\"intro-sub\" id=\"intro-sub\"></div>\n  <p class=\"intro-story\" id=\"intro-story\"></p>\n  <div class=\"intro-mission\" id=\"intro-mission\"></div>\n  <button class=\"intro-btn\" onclick=\"startGame()\">Enter the Mansion</button>\n</div>\n\n<!-- GAME -->\n<div id=\"game\" class=\"screen\">\n  <div id=\"rooms-col\"></div>\n  <div id=\"right-col\">\n    <div class=\"rp-header\">\n      <div class=\"rp-case-title\" id=\"rp-case-title\"></div>\n      <div class=\"timer-row\">\n        <div class=\"timer-display\" id=\"timer-display\">45:00</div>\n        <div style=\"font-size:.65rem;color:var(--muted);\" id=\"progress-label\">0 / 6 rooms</div>\n      </div>\n    </div>\n    <div class=\"progress-strip\" id=\"progress-strip\"></div>\n    <div id=\"puzzle-panel\"><div class=\"pp-empty\">Click a room to investigate</div></div>\n  </div>\n</div>\n\n<!-- SUCCESS -->\n<div id=\"success\" class=\"screen\">\n  <div class=\"suc-icon\">&#127881;</div>\n  <div class=\"suc-title\">Case Closed!</div>\n  <div class=\"suc-sub\">Escape Room Complete</div>\n  <div class=\"suc-time\" id=\"suc-time\"></div>\n  <div class=\"suc-msg\" id=\"suc-msg\"></div>\n  <button class=\"suc-btn\" onclick=\"location.reload()\">Play Again</button>\n</div>\n\n<script>\n// ── DATA ─────────────────────────────────────────────────────────────────────\nvar E = {\n  title: \"The Whitmoor Mansion Mystery\",\n  subtitle: \"An EFL Escape Room\",\n  story: \"It is <strong>1923</strong>. You and your team of private detectives have been summoned to the <strong>Whitmoor Mansion</strong>. The notorious criminal known only as \\\"The Shadow\\\" has hidden a stolen artefact somewhere inside. You have <strong>45 minutes</strong> before the morning train arrives and the criminal escapes forever.\",\n  mission: \"Explore each room of the mansion. Solve the language challenge inside to unlock the next. Find the hidden code and catch The Shadow before time runs out.\",\n  success: \"The artefact is recovered. The Shadow is arrested at the station. Your team's mastery of language has saved the day. Scotland Yard sends its congratulations.\",\n  rooms: [\n    { id:\"entrance\", name:\"Entrance Hall\",  icon:\"&#127968;\", color:\"#c8922a\", skill:\"Vocabulary\",\n      instruction:\"Study the names on the guest register. Each name contains a HIDDEN WORD. Find the hidden word inside each name and write the FIRST LETTERS of all 4 hidden words to make the 4-letter code.\",\n      task:\"1. MARGARET  \\u2192  hidden word: _ _ _ (a colour)\\n2. FLORENCE  \\u2192  hidden word: _ _ _ _ (a direction)\\n3. STANDISH  \\u2192  hidden word: _ _ _ _ (a verb meaning 'to remain')\\n4. BLACKWOOD  \\u2192  hidden word: _ _ _ _ (the opposite of white)\",\n      answer:\"RNSB\",\n      hint:\"Colours, directions, and opposites are hidden inside the names. Try underlining letters in the middle of each name.\"\n    },\n    { id:\"library\", name:\"Library\",        icon:\"&#128218;\", color:\"#3b82f6\", skill:\"Grammar — Past Simple vs. Past Perfect\",\n      instruction:\"Read the witness statements. Each statement has ONE grammatical error (Past Simple vs. Past Perfect). Find the CORRECTED VERB in each sentence. Take the FIRST LETTER of each corrected verb to spell the 4-letter code.\",\n      task:\"1. By the time we arrived, the thief already LEFT the building.\\n   \\u2192 Correct verb: had _______ (4 letters)\\n2. Sh