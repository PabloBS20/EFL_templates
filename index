  msg.textContent = text;
  msg.className = 'msg ' + (type || 'error');
  setTimeout(function(){
    if (selectedIndices.length === 0) msg.style.display = 'none';
  }, 1500);
}

async function submitWord() {
  var word = selectedIndices.map(function(i){return grid[i];}).join('');
  if (word.length < 4) {
    showMessage("4 letters minimum!");
    clearPath();
    return;
  }
  
  var btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = "...";
  
  var isTarget = false;
  targetWords.forEach(function(w){ if(w.toUpperCase() === word) isTarget = true; });
  
  if (isTarget) {
    if (foundTargets.indexOf(word) > -1) {
      showMessage("Already found!");
    } else {
      foundTargets.push(word);
      showMessage("Theme Word!", "success");
      renderTargets();
      checkWin();
    }
    btn.disabled = false;
    btn.textContent = "Submit";
    clearPath();
    return;
  }
  
  if (foundBonus.indexOf(word) > -1) {
    showMessage("Bonus already found!");
    btn.disabled = false;
    btn.textContent = "Submit";
    clearPath();
    return;
  }
  
  // Verify with free dictionary API
  try {
    var res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + word.toLowerCase());
    if (res.ok) {
      foundBonus.push(word);
      showMessage("Bonus Word!", "success");
      addHintPoint();
      renderBonus();
    } else {
      showMessage("Not a valid word");
    }
  } catch(e) {
    // If offline, accept it to keep the game playable
    foundBonus.push(word);
    showMessage("Bonus Word!", "success");
    addHintPoint();
    renderBonus();
  }
  
  btn.disabled = false;
  btn.textContent = "Submit";
  clearPath();
}

function addHintPoint() {
  hintPoints++;
  if (hintPoints >= 3) {
    hintPoints = 0;
    hintsAvailable++;
  }
  renderHintMeter();
}

function renderHintMeter() {
  var dots = document.querySelectorAll('.hint-dot');
  dots.forEach(function(dot, i) {
    if (i < hintPoints) dot.classList.add('filled');
    else dot.classList.remove('filled');
  });
  
  var btn = document.getElementById('useHintBtn');
  btn.disabled = hintsAvailable <= 0;
  if (hintsAvailable > 0) btn.textContent = "USE HINT (" + hintsAvailable + ")";
  else btn.textContent = "USE HINT";
}

function useHint() {
  if (hintsAvailable <= 0) return;
  var unfound = targetWords.filter(function(w){ return foundTargets.indexOf(w.toUpperCase()) === -1; });
  if (unfound.length === 0) return;
  
  var word = unfound[Math.floor(Math.random() * unfound.length)].toUpperCase();
  hintsAvailable--;
  
  var arr = word.split('');
  arr.sort(function(){return Math.random() - 0.5;});
  revealedHints[word] = arr.join(' ');
  
  renderHintMeter();
  renderTargets();
}

function renderTargets() {
  var list = document.getElementById('targetsList');
  list.innerHTML = '';
  targetWords.forEach(function(w) {
    var word = w.toUpperCase();
    var div = document.createElement('div');
    div.className = 'target-word';
    if (foundTargets.indexOf(word) > -1) {
      div.textContent = word;
      div.classList.add('found');
    } else if (revealedHints[word]) {
      div.textContent = revealedHints[word];
      div.classList.add('hinted');
    } else {
      div.textContent = word.replace(/./g, '_ ');
    }
    list.appendChild(div);
  });
}

function renderBonus() {
  document.getElementById('bonusCount').textContent = foundBonus.length;
  var list = document.getElementById('bonusList');
  list.innerHTML = '';
  foundBonus.forEach(function(w){
    var div = document.createElement('div');
    div.className = 'bonus-word';
    div.textContent = w;
    list.appendChild(div);
  });
}

function checkWin() {
  if (foundTargets.length >= targetWords.length) {
    document.getElementById('resBonus').textContent = foundBonus.length;
    document.getElementById('results').style.display = 'flex';
  }
}

// Start Game
init();
<\/script>
